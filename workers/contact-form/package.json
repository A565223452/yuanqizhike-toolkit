{
  "name": "yuanqizhike-contact-worker",
  "version": "1.0.0",
  "private": true,
  "description": "留言表单 Worker：接收 + Turnstile 校验 + D1 存储 + Resend 发信",
  "type": "module",
  "scripts": {
