# 本地开发环境变量样例（复制为 .dev.vars 后填入真实值）
# 用法：cp .dev.vars.example .dev.vars

# Cloudflare Turnstile（后台 → Turnstile → 创建站点）
TURNSTILE_SITE_KEY=your_site_key_here
TURNSTILE_SECRET_KEY=your_secret_key_here

# Resend（https://resend.com → API Keys）
RESEND_API_KEY=re_xxxxxxxxxxxxx

# 后台查询接口的 Bearer Token（自定义随机字符串，建议 32 位以上）
ADMIN_TOKEN=your_random_admin_token_here

# 允许的前端来源（CORS）
ALLOWED_ORIGIN=https://yuanqizhike.com

# 收件人 / 发件人
CONTACT_TO_EMAIL=260330663@qq.com
CONTACT_FROM_EMAIL=noreply@yuanqizhike.com
